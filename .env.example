NEXT_PUBLIC_MUX_SHOWREEL_PLAYBACK_ID=
NEXT_PUBLIC_MUX_HOUSE_SHOWREEL_PLAYBACK_ID=
NEXT_PUBLIC_MUX_FESTIVAL_SHOWREEL_PLAYBACK_ID=

# Safe for browser exposure. Used by the Next.js frontend to read published Sanity content.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Server-side only. Keep empty for public published reads; reserve for future preview/private reads.
SANITY_API_READ_TOKEN=

# Server-side only. Public origin of the separately deployed Sanity Studio, for example:
# https://your-studio-deployment.vercel.app
# The root website uses this to proxy /studio and /studio/* to the Studio app.
SANITY_STUDIO_ORIGIN=
